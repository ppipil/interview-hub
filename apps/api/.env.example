# Current MVP runtime
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://your-site.netlify.app,https://your-site.vercel.app
BACKEND_CORS_ORIGIN_REGEX=https?://(127\.0\.0\.1|localhost)(:\d+)?|https://[A-Za-z0-9-]+\.(netlify|vercel)\.app
DATABASE_URL=
# SQLite example:
# DATABASE_URL=sqlite:///./interview-hub.sqlite3
# Neon/Postgres example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/neondb?sslmode=require

# Current SecondMe legacy integration
SECONDME_BASE_URL=https://mindos-prek8s.mindverse.ai/gate/in
