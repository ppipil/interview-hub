# Optional provider and database variables
# These are consumed when you enable Visitor Chat, Doubao, or database persistence.
SECONDME_VISITOR_BASE_URL=https://api.mindverse.com/gate/lab
SECONDME_APP_CLIENT_ID=
SECONDME_APP_CLIENT_SECRET=
# Testing shortcut: paste a manually generated target avatar key here.
# Never commit a real sk- value.
# If you accidentally put it in SECONDME_API_KEY, the API has a temporary
# compatibility fallback, but SECONDME_AVATAR_API_KEY is the intended name.
SECONDME_AVATAR_API_KEY=
# Fallback for a single default avatar. If you manage multiple avatars or
# app-side interviewer skills, store them in the interviewer_profiles table.
SECONDME_OAUTH_AUTHORIZE_URL=https://go.second-me.cn/oauth/
SECONDME_OAUTH_TOKEN_URL=https://api.mindverse.com/gate/lab/api/oauth/token/code
SECONDME_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/secondme/callback
SECONDME_OAUTH_SCOPES=userinfo chat.write avatar.read
SECONDME_OAUTH_STATE_SECRET=
SECONDME_AVATAR_API_KEY_NAME=Interview Hub
FRONTEND_AUTH_SUCCESS_URL=http://localhost:5173/setup
FRONTEND_AUTH_ERROR_URL=http://localhost:5173/setup

DOUBAO_API_KEY=
DOUBAO_MODEL=
